# Backend server
PORT=3000
NODE_ENV=development

# Supabase project credentials.
# Do not commit real values.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Backend only. Never expose this key in the Expo app or any client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Local Expo dev server origin. Adjust when using a physical device or deployed frontend.
CORS_ORIGIN=http://localhost:8081
